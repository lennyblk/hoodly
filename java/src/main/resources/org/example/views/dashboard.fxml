<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.DashboardController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

   <HBox alignment="CENTER_RIGHT" spacing="10">
       <Button text="Synchroniser données (Internet)" onAction="#handleSync" />
       <Button text="Déconnexion" onAction="#handleLogout" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
   </HBox>

   <Label fx:id="welcomeLabel" text="Welcome!" style="-fx-font-size: 28; -fx-font-weight: bold;" />
   <Label fx:id="dbStatusLabel" text="Connexion base..." />

   <HBox alignment="CENTER" spacing="20">
       <VBox alignment="CENTER" spacing="10" style="-fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: #fafafa; -fx-padding: 30;">
           <Label text="Gestion des Incidents/Alertes" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
           <Label text="Fonctionnera offline-first." />
           <Button text="Afficher Incidents" />
       </VBox>
       
       <VBox alignment="CENTER" spacing="10" style="-fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: #fafafa; -fx-padding: 30;">
           <Label text="Statistiques Globales" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
           <Label text="Participation quartier." />
           <Button text="Afficher Stats" />
        </VBox>
   </HBox>
</VBox>