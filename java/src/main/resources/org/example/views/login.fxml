<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllers.LoginController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>

   <Label text="Connexion Administrateur" style="-fx-font-size: 24; -fx-font-weight: bold;" />
   <Label text="Veuillez utiliser votre compte Hoodly" />

   <TextField fx:id="emailField" promptText="Adresse e-mail" minWidth="250.0" />
   <PasswordField fx:id="passwordField" promptText="Mot de passe" />

   <Label fx:id="errorLabel" textFill="red" />

   <Button text="Se connecter (SSO)" onAction="#handleLogin" minWidth="250.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
</VBox>